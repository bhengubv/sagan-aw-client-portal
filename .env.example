# AW Client Report Portal — environment template.
# Copy to .env (loaded via python-dotenv) and fill for your environment.
# Secrets must NEVER be committed (spec §13). .env is gitignored.

# ---- Core ----
SECRET_KEY=change-me-to-a-long-random-string
# Vault key for encrypting provider credentials at rest (urlsafe base64 Fernet key).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, a key is derived from SECRET_KEY (fine for dev; set explicitly in prod and BACK IT UP —
# rotating it makes all stored provider credentials undecryptable).
VAULT_KEY=

# ---- Database ----
# Dev default is SQLite under instance/. For production use Postgres (spec §6.3):
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/aw_portal
RAILWAY_DATABASE_PATH=
DATABASE_URL=

# ---- Public links (client-facing onboarding / expense worksheet) ----
PUBLIC_BASE_URL=https://portal.yourfirm.com

# ---- Email / distribution (spec §8.10) ----
# Without SMTP_HOST, email is recorded to the in-app Outbox (functional, not delivered).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourfirm.com
SMTP_STARTTLS=1

# ---- AI (spec §12). Optional. Without a key the deterministic extractor runs. ----
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-opus-4-8

# ---- Providers ----
# Provider credentials/base_urls are NOT set here — they are configured per-tenant in the
# app (Settings -> Data providers) and stored encrypted in the vault. See docs/PROVIDERS.md.
# In dev, point each provider's base_url at the sandbox, e.g. http://127.0.0.1:5050/plaid
